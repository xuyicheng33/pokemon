	result_panel = root.get_node(PATH_RESULT_PANEL) as PanelContainer
	result_summary = root.get_node(PATH_RESULT_SUMMARY) as RichTextLabel
	result_restart_button = root.get_node(PATH_RESULT_RESTART_BUTTON) as Button
	return_select_button = root.get_node(PATH_RETURN_SELECT_BUTTON) as Button
