	utility_buttons = root.get_node(PATH_UTILITY_BUTTONS) as Container
	restart_button = root.get_node(PATH_RESTART_BUTTON) as Button
	replay_controls = root.get_node(PATH_REPLAY_CONTROLS) as HBoxContainer
